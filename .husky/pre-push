#!/usr/bin/env bash
set -euo pipefail

echo ""
echo "╔══════════════════════════════════════════╗"
echo "║         ZeroNoShow — pre-push checks     ║"
echo "╚══════════════════════════════════════════╝"
echo ""

# Vérifie que le container api est démarré
if ! docker compose ps --status running api 2>/dev/null | grep -q "api"; then
  echo "✗ Le container 'api' n'est pas démarré."
  echo "  Lance 'make up' puis réessaie."
  exit 1
fi

echo "▶ [1/5] Backend — Pint (code style)"
docker compose exec -T api php artisan config:clear >/dev/null
docker compose exec -T api ./vendor/bin/pint --test

echo "▶ [2/5] Backend — PHPStan (static analysis)"
docker compose exec -T api ./vendor/bin/phpstan analyse -c phpstan.neon --memory-limit=512M

echo "▶ [3/5] Backend — Pest (tests)"
docker compose exec -T \
  -e APP_ENV=testing \
  -e DB_CONNECTION=sqlite \
  -e DB_DATABASE=:memory: \
  -e CACHE_STORE=array \
  -e QUEUE_CONNECTION=sync \
  api ./vendor/bin/pest --stop-on-failure

echo "▶ [4/5] Frontend — Prettier + ESLint (check only)"
(cd frontend && pnpm exec prettier --check .)
(cd frontend && pnpm exec eslint . --cache)

echo "▶ [5/5] Frontend — Vitest (tests)"
(cd frontend && pnpm exec vitest run)

echo ""
echo "✓ Tous les checks sont passés — push autorisé."
echo ""
