#!/usr/bin/env sh
set -eu

echo
echo "========================================="
echo " ZeroNoShow pre-push checks"
echo "========================================="
echo

if ! docker compose ps --status running api 2>/dev/null | grep -q "api"; then
  echo "Container 'api' is not running."
  echo "Run 'make up' and try again."
  exit 1
fi

echo "[1/5] Backend - Pint"
docker compose exec -T api php artisan config:clear >/dev/null
docker compose exec -T api ./vendor/bin/pint --test

echo "[2/5] Backend - PHPStan"
docker compose exec -T api ./vendor/bin/phpstan analyse -c phpstan.neon --memory-limit=512M

echo "[3/5] Backend - Pest"
docker compose exec -T \
  -e APP_ENV=testing \
  -e DB_CONNECTION=sqlite \
  -e DB_DATABASE=:memory: \
  -e CACHE_STORE=array \
  -e QUEUE_CONNECTION=sync \
  api ./vendor/bin/pest --stop-on-failure

echo "[4/5] Frontend - Prettier + ESLint"
docker compose run --rm frontend pnpm exec prettier --check .
docker compose run --rm frontend pnpm exec eslint . --cache

echo "[5/5] Frontend - Vitest"
docker compose run --rm frontend pnpm exec vitest run

echo
echo "All checks passed. Push allowed."
echo
